# URL publique de l'API vue par le browser
# Vide = URLs relatives (proxied via SvelteKit hooks sur /api)
# Dev local sans proxy : http://127.0.0.1:3001
PUBLIC_API_BASE=

# URL interne de l'API pour le SSR (server-side)
# Dev local : pas besoin (fallback localhost:3001)
# Docker : http://api:3001
API_BASE_INTERNAL=
