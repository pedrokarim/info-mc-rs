API_PORT=3001
WEB_PORT=3000

# Admin — Discord OAuth (requis pour le panneau admin)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:3001/api/v1/admin/auth/callback

# Admin — JWT (optionnel, auto-généré si absent mais sessions perdues au restart)
JWT_SECRET=

# Likes — sel pour hasher les IPs (optionnel)
IP_HASH_SALT=
