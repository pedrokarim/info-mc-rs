# ── Docker Compose ──
API_PORT=3001
WEB_PORT=3000

# ── API (Rust) ──

# Admin — Discord OAuth (requis pour le panneau admin)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/admin/login

# Admin — JWT (optionnel, auto-généré si absent mais sessions perdues au restart)
JWT_SECRET=

# Likes — sel pour hasher les IPs (optionnel, auto-généré si absent)
IP_HASH_SALT=

# ── Web (SvelteKit) ──

# URL publique de l'API vue par le browser (vide = relative, proxied via /api)
# En dev local sans Docker : http://127.0.0.1:3001
# En Docker : laisser vide (le proxy SvelteKit s'en occupe)
PUBLIC_API_BASE=

# URL interne de l'API pour le SSR (server-side uniquement)
# En dev local : pas besoin (fallback sur localhost:3001)
# En Docker : http://api:3001
API_BASE_INTERNAL=
